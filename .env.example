# Create a bot with @BotFather on Telegram and put its token here
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenReplaceMe
# Chat id to send notifications to (your own user id, or a group/channel id)
TELEGRAM_CHAT_ID=123456789

# How often to poll, in minutes (a random +/- jitter is added so requests
# don't fire at a perfectly predictable interval)
POLL_INTERVAL_MINUTES=5
POLL_JITTER_MINUTES=1

# Only notify about tickets within this many days from today
LOOKAHEAD_DAYS=60

# Set to false to watch the browser while debugging locally
HEADLESS=true
